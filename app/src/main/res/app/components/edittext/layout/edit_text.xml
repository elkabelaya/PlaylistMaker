<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <variable
            name="hint"
            type="String" />
    </data>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/padding_m"
        android:textColorHint="@color/text_title"
        app:boxStrokeColor="@color/edit_text_box_stroke_colors"
        app:hintTextColor="@color/edittext_border_color"
        app:cursorColor="@color/text_title"
        app:boxStrokeWidth="@dimen/edittext_border_height"
        app:boxStrokeWidthFocused="@dimen/edittext_border_height"

        android:hint="@{hint}">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input"
            android:layout_width="match_parent"
            android:layout_height="@dimen/edittext_height"
            android:defaultFocusHighlightEnabled="false"
            android:inputType="text"
            android:lines="1"
            android:fontFamily="@font/ys_display_regular"
            android:textSize="@dimen/text_m"
            android:textColor="@color/text_title"
            tools:hint="@tools:sample/lorem"
            />
    </com.google.android.material.textfield.TextInputLayout>

</layout>