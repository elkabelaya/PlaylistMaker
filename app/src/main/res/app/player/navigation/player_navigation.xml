<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:id="@+id/player_navigation"
app:startDestination="@id/player_fragment">

    <fragment
        android:id="@+id/player_fragment"
        android:name="com.example.playlistmaker.player.presentation.PlayerFragment"
        android:label="fragment_player"
        tools:layout="@layout/fragment_player">
        <action
            android:id="@+id/action_player_newplaylistFragment"
            app:destination="@id/newplaylist_fragment"
            app:popUpTo="@id/player_fragment"
            style="@style/NavigationAnimation"
            app:launchSingleTop="true" />
    </fragment>

    <fragment
        android:id="@+id/newplaylist_fragment"
        android:name="com.example.playlistmaker.newplaylist.presentation.NewPlaylistFragment"
        android:label="fragment_newplaylist"
        tools:layout="@layout/fragment_newplaylist"/>
</navigation>