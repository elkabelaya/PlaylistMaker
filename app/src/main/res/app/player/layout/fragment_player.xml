<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".player.presentation.PlayerFragment">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/main"
        android:orientation="vertical"
        android:background="@color/background"
        android:paddingBottom="@dimen/padding_4xl">
        <include
            android:id="@+id/toolbar"
            layout="@layout/toolbar"/>
        <ScrollView android:layout_width="match_parent"
            android:layout_height="match_parent"
            >
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/padding_xl"
                android:layout_marginRight="@dimen/padding_xl">
                <ImageView
                    android:id="@+id/image_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    app:cornerRadius="@dimen/radius_xs"
                    app:layout_constraintDimensionRatio="1:1"
                    android:scaleType="centerCrop"
                    app:layout_constraintTop_toTopOf="parent"
                    />
                <TextView
                    android:id="@+id/title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/ys_display_medium"
                    android:textSize="@dimen/text_xl"
                    android:textColor="@color/text_title"
                    app:layout_constraintTop_toBottomOf="@id/image_view"
                    android:layout_marginTop="@dimen/padding_xl"/>
                <TextView
                    android:id="@+id/artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/ys_display_medium"
                    android:textSize="@dimen/text_xm"
                    android:textColor="@color/text_title"
                    app:layout_constraintTop_toBottomOf="@id/title"
                    android:layout_marginTop="@dimen/padding_s"/>

                <ImageButton
                    android:id="@+id/add_view"
                    style="@style/player_button"
                    android:src="@drawable/ic_player_add"
                    android:layout_marginTop="@dimen/padding_8xl"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/play_view"
                    app:layout_constraintTop_toBottomOf="@id/artist"
                    app:layout_constraintHorizontal_chainStyle="spread_inside"/>
                <ImageButton
                    android:id="@+id/play_view"
                    style="@style/player_play_button"
                    android:src="@drawable/ic_player_play_button"
                    android:layout_marginTop="@dimen/padding_6xl"
                    app:layout_constraintStart_toEndOf="@id/add_view"
                    app:layout_constraintEnd_toStartOf="@id/favorite_view"
                    app:layout_constraintTop_toBottomOf="@id/artist"/>
                <ImageButton
                    android:id="@+id/favorite_view"
                    style="@style/player_button"
                    android:src="@drawable/ic_player_heart_stroke"
                    app:layout_constraintStart_toEndOf="@id/play_view"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/add_view"/>


                <TextView
                    android:id="@+id/time_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:fontFamily="@font/ys_display_medium"
                    android:textSize="@dimen/text_xm"
                    android:textColor="@color/text_title"
                    app:layout_constraintTop_toBottomOf="@id/play_view"
                    android:layout_marginTop="@dimen/padding_s" />

                <TextView
                    android:id="@+id/duration_label"
                    style="@style/player_label"
                    app:layout_constraintTop_toBottomOf="@id/time_view"
                    app:layout_constraintLeft_toLeftOf="parent"
                    android:text="@string/player_duration"
                    android:layout_marginTop="@dimen/padding_5xl"/>
                <TextView
                    android:id="@+id/album_label"
                    style="@style/player_label"
                    app:layout_constraintTop_toBottomOf="@id/duration_label"
                    app:layout_constraintLeft_toLeftOf="parent"
                    android:text="@string/player_album"
                    />
                <TextView
                    android:id="@+id/year_label"
                    style="@style/player_label"
                    app:layout_constraintTop_toBottomOf="@id/album"
                    app:layout_constraintLeft_toLeftOf="parent"
                    android:text="@string/player_year"
                    />
                <TextView
                    android:id="@+id/genre_label"
                    style="@style/player_label"
                    app:layout_constraintTop_toBottomOf="@id/year_label"
                    app:layout_constraintLeft_toLeftOf="parent"
                    android:text="@string/player_genre"
                    />
                <TextView
                    android:id="@+id/country_label"
                    style="@style/player_label"
                    app:layout_constraintTop_toBottomOf="@id/genre_label"
                    app:layout_constraintLeft_toLeftOf="parent"
                    android:text="@string/player_country"
                    />


                <androidx.constraintlayout.widget.Barrier
                    android:id="@+id/barrier"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:barrierDirection="right"
                    app:constraint_referenced_ids="duration_label, album_label, year_label, genre_label, country_label" />

                <TextView
                    android:id="@+id/duration"
                    style="@style/player_info"
                    app:layout_constraintTop_toBottomOf="@id/time_view"
                    app:layout_constraintLeft_toRightOf="@id/barrier"
                    app:layout_constraintRight_toRightOf="parent"
                    android:layout_marginTop="@dimen/padding_5xl" />
                <TextView
                    android:id="@+id/album"
                    style="@style/player_album_info"
                    app:layout_constraintTop_toBottomOf="@id/duration"
                    app:layout_constraintLeft_toRightOf="@id/barrier"
                    app:layout_constraintRight_toRightOf="parent" />
                <TextView
                    android:id="@+id/year"
                    style="@style/player_info"
                    app:layout_constraintTop_toBottomOf="@id/album"
                    app:layout_constraintLeft_toRightOf="@id/barrier"
                    app:layout_constraintRight_toRightOf="parent"/>
                <TextView
                    android:id="@+id/genre"
                    style="@style/player_info"
                    app:layout_constraintTop_toBottomOf="@id/year"
                    app:layout_constraintLeft_toRightOf="@id/barrier"
                    app:layout_constraintRight_toRightOf="parent"/>
                <TextView
                    android:id="@+id/country"
                    style="@style/player_info"
                    app:layout_constraintTop_toBottomOf="@id/genre"
                    app:layout_constraintLeft_toRightOf="@id/barrier"
                    app:layout_constraintRight_toRightOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>
    </LinearLayout>
    <View android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/yp_background"
        android:visibility="gone"/>
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        app:behavior_hideable="true"
        app:behavior_peekHeight="505dp"
        style="@style/bottom_sheet"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">
        <include layout="@layout/bottom_sheet_handle_view"
            android:id="@+id/bottom_sheet_handle"
            />
        <TextView
            style="@style/action_button"
            android:text="@string/player_playlist_title"
            android:textColor="@color/text_title"
            android:textSize="@dimen/text_l"
            android:fontFamily="@font/ys_display_medium"
            android:layout_marginTop="@dimen/padding_ml"
            android:layout_marginBottom="@dimen/padding_s"/>
        <Button android:id="@+id/create_button"
            style="@style/action_button"
            android:text="@string/player_playlist_create"
            android:layout_marginTop="@dimen/padding_m"
            android:layout_marginBottom="@dimen/padding_xl"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playlists"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="16dp"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="2"
            tools:itemCount="2"
            tools:listitem="@layout/media_playlist_card_view"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>