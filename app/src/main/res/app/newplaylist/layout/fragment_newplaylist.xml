<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/background"
    android:orientation="vertical"
    tools:context=".newplaylist.presentation.NewPlaylistFragment">

    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="@dimen/padding_m"
        android:layout_marginTop="@dimen/padding_2xl"
        >
        <ImageView
            android:id="@+id/add_picture"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="1:1"
            android:background="@drawable/bg_newplaylist_add_photo"
            android:scaleType="center"
            android:src="@drawable/ic_newplaylist_add_photo"
            android:layout_marginHorizontal="@dimen/padding_xs"
            app:layout_constraintTop_toTopOf="parent"
            />

        <ImageView
            android:id="@+id/image_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:cornerRadius="@dimen/radius_xs"
            app:layout_constraintDimensionRatio="1:1"
            android:scaleType="centerCrop"
            android:layout_marginHorizontal="@dimen/padding_xs"
            app:layout_constraintTop_toTopOf="parent"
            android:visibility="gone"
            />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:barrierAllowsGoneWidgets="false"
            app:constraint_referenced_ids="add_picture,image_view" />

        <include android:id="@+id/name"
            layout="@layout/edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_5xl"
            app:layout_constraintTop_toBottomOf="@id/barrier"
            />

        <include android:id="@+id/description"
            layout="@layout/edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_m"
            app:layout_constraintTop_toBottomOf="@id/name"/>

        <Button
            android:id="@+id/create_button"
            style="@style/app_button"
            android:text="@string/newplaylist_create_button"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>