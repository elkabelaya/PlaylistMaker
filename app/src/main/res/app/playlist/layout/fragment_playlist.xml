<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".player.presentation.PlayerFragment">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/playlist_background">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/padding_xl"
        android:id="@+id/content"
        android:orientation="vertical">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/image_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:padding="@dimen/padding_7xl"
                    app:layout_constraintDimensionRatio="1:1"
                    android:scaleType="centerCrop"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:src="@tools:sample/avatars"
                    tools:background="@color/yp_white"
                    />
                <include
                    android:id="@+id/toolbar"
                    layout="@layout/toolbar"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/padding_m"
                android:layout_marginRight="@dimen/padding_m"
                android:layout_marginTop="@dimen/padding_xl"
                >
                <TextView
                    android:id="@+id/title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/ys_display_bold"
                    android:textSize="@dimen/text_xxl"
                    android:textColor="@color/yp_black"
                    tools:text="@tools:sample/lorem"/>
                <TextView
                    android:id="@+id/year"
                    style="@style/playlist_text"
                    app:layout_constraintTop_toBottomOf="@id/title"
                    android:layout_marginTop="@dimen/padding_xs"
                    tools:text="@tools:sample/lorem"/>
                <TextView
                    android:id="@+id/time"
                    style="@style/playlist_text"
                    app:layout_constraintTop_toBottomOf="@id/year"
                    android:layout_marginTop="@dimen/padding_xs"
                    tools:text="@tools:sample/lorem"/>
                <ImageView
                    android:id="@+id/dot"
                    android:src="@drawable/ic_dot"
                    android:layout_width="@dimen/icon_s"
                    android:layout_height="@dimen/icon_s"
                    android:tint="@color/yp_black"
                    app:layout_constraintTop_toTopOf="@id/time"
                    app:layout_constraintBottom_toBottomOf="@id/time"
                    app:layout_constraintLeft_toRightOf="@id/time"/>
                <TextView
                    android:id="@+id/count"
                    style="@style/playlist_text"
                    app:layout_constraintTop_toTopOf="@id/time"
                    app:layout_constraintLeft_toRightOf="@id/dot"
                    tools:text="@tools:sample/lorem"/>

                <ImageButton
                    android:id="@+id/share_button"
                    style="@style/playlist_image_button"
                    android:src="@drawable/ic_share"
                    android:layout_marginTop="@dimen/padding_m"
                    app:layout_constraintTop_toBottomOf="@id/time" />
                <ImageButton
                    android:id="@+id/menu_button"
                    style="@style/playlist_image_button"
                    android:src="@drawable/ic_vertical_dots"
                    android:layout_marginLeft="@dimen/padding_m"
                    app:layout_constraintStart_toEndOf="@id/share_button"
                    app:layout_constraintTop_toTopOf="@id/share_button" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    <Space
        android:id="@+id/empty_bottom"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    </LinearLayout>

    <include android:id="@+id/tracks_bottom_sheet"
        layout="@layout/playlist_tracks_bottom_sheet"
        tools:visibility="gone"/>
    <include
        android:id="@+id/overlay"
        layout="@layout/bottom_sheet_overlay"/>
    <include android:id="@+id/menu_bottom_sheet"
        layout="@layout/playlist_menu_bottom_sheet"
        tools:visibility="gone"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>